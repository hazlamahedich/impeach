{
  "name": "impeachment-watch",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Impeachment Intelligence Platform (IIP) — Turborepo monorepo root.",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "vitest run tests/smoke && turbo run test",
    "lint": "eslint .",
    "eval:uv": "uv run --project tools/eval python -m eval"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "turbo": "^2.9.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^2.1.8"
  }
}
