+++ b/infra/docker-compose.yml
@@ -0,0 +1,332 @@
+# Docker Compose Platform Stack — IIP v1
+#
+# @rules AC-3, STR-2 (6-process split), D9, D15, NFR-O-1, NFR-S-5
+# @adr ADR-001, ADR-004, ADR-005, ADR-021
+#
+# Single-workstation topology (TRANSITIONAL — AC-3). All external dependencies
+# are behind env-driven interfaces (SC-5 → multi-node = deployment change).
+#
+# NOTE: Relative paths in this file resolve from infra/ (the compose file dir).
+# Build contexts use `..` to reach the project root.
+#
+# Usage:
+#   docker compose -f infra/docker-compose.yml up -d --wait
+#   docker compose -f infra/docker-compose.yml ps
+#   docker compose -f infra/docker-compose.yml down -v
+
+name: iip
+
+services:
+  # ─── Data Layer ────────────────────────────────────────────────
+
+  postgres:
+    # Uses Story 1.2 custom image (PG16 + AGE + pgvector + pg_trgm).
+    # Override via IIP_PG_AGE_VECTOR_IMAGE for CI/digest-pinned deployments.
+    image: ${IIP_PG_AGE_VECTOR_IMAGE:-ghcr.io/iip/postgres-age-pgvector:pg16}
+    environment:
+      POSTGRES_USER: ${POSTGRES_USER:-postgres}
+      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-changeme}
+      POSTGRES_DB: ${POSTGRES_DB:-iip}
+    # Host port is optional — set PG_HOST_PORT to expose for local tooling
+    ports:
+      - "${PG_HOST_PORT:-}:5432"
+    volumes:
+      - pgdata:/var/lib/postgresql/data
+      - ./sql/age/migrations:/age-migrations:ro
+    healthcheck:
+      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-postgres} -d ${POSTGRES_DB:-iip}"]
+      interval: 5s
+      timeout: 3s
+      start_period: 10s
+      retries: 5
+
+  redis:
+    image: redis:7-alpine
+    # Host port is optional — set REDIS_HOST_PORT to expose for local tooling
+    ports:
+      - "${REDIS_HOST_PORT:-}:6379"
+    volumes:
+      - redisdata:/data
+    command: redis-server --appendonly yes --save 60 1000
+    healthcheck:
+      test: ["CMD", "redis-cli", "ping"]
+      interval: 5s
+      timeout: 3s
+      start_period: 5s
+      retries: 5
+
+  minio:
+    image: minio/minio:latest
+    command: server /data --console-address ":9001"
+    # Host port is optional — set MINIO_HOST_PORT to expose for local tooling
+    ports:
+      - "${MINIO_HOST_PORT:-}:9000"
+      - "${MINIO_CONSOLE_PORT:-}:9001"
+    environment:
+      MINIO_ACCESS_KEY: ${MINIO_ACCESS_KEY:-minioadmin}
+      MINIO_SECRET_KEY: ${MINIO_SECRET_KEY:-minioadmin}
+    volumes:
+      - miniodata:/data
+    healthcheck:
+      test: ["CMD", "mc", "ready", "local"]
+      interval: 5s
+      timeout: 3s
+      start_period: 10s
+      retries: 5
+
+  # MinIO bucket init sidecar — creates raw-snapshots bucket idempotently
+  minio-init:
+    image: minio/mc:latest
+    depends_on:
+      minio:
+        condition: service_healthy
+    entrypoint: >
+      /bin/sh -c "
+      mc alias set local http://minio:9000 ${MINIO_ACCESS_KEY:-minioadmin} ${MINIO_SECRET_KEY:-minioadmin} &&
+      mc mb local/raw-snapshots --ignore-existing &&
+      mc anonymous set none local/raw-snapshots 2>/dev/null || true &&
+      echo 'raw-snapshots bucket ready (private, off serving path)'
+      "
+    restart: "no"
+
+  # ─── LLM ────────────────────────────────────────────────────────
+
+  ollama:
+    image: ollama/ollama:latest
+    # Internal-only — NOT exposed externally (Dev Notes point 4, NFR-S-5 spirit).
+    # Apps connect via Docker network: http://ollama:11434
+    volumes:
+      - ollamadata:/root/.ollama
+    # GPU passthrough — uncomment for NVIDIA (Linux)
+    # deploy:
+    #   resources:
+    #     reservations:
+    #       devices:
+    #         - driver: nvidia
+    #           count: all
+    #           capabilities: [gpu]
+    healthcheck:
+      test: ["CMD-SHELL", "ollama list >/dev/null 2>&1"]
+      interval: 10s
+      timeout: 5s
+      start_period: 30s
+      retries: 5
+
+  # Ollama model pre-pull sidecar — pulls qwen3:14b before first serve
+  ollama-pull:
+    image: ollama/ollama:latest
+    depends_on:
+      ollama:
+        condition: service_healthy
+    environment:
+      OLLAMA_HOST: http://ollama:11434
+      OLLAMA_MODEL: ${OLLAMA_MODEL:-qwen3:14b}
+    entrypoint: >
+      /bin/sh -c "
+      echo 'Pulling ${OLLAMA_MODEL:-qwen3:14b}...' &&
+      ollama pull ${OLLAMA_MODEL:-qwen3:14b} &&
+      echo 'Model pulled successfully.'
+      "
+    restart: "no"
+
+  # ─── App Processes (6-process split — STR-2, ADR-021) ───────────
+
+  api:
+    build:
+      context: ..
+      dockerfile: infra/docker/Dockerfile.app
+      args:
+        APP_NAME: '@iip/api'
+    depends_on:
+      postgres:
+        condition: service_healthy
+      redis:
+        condition: service_healthy
+    environment:
+      DATABASE_URL: postgres://${POSTGRES_USER:-postgres}:${POSTGRES_PASSWORD:-changeme}@postgres:5432/${POSTGRES_DB:-iip}?options=-c%20search_path%3Dag_catalog%2Cpublic
+      REDIS_URL: redis://redis:6379
+    healthcheck:
+      test: ["CMD-SHELL", "node -e \"console.log('alive')\" || exit 1"]
+      interval: 10s
+      timeout: 5s
+      start_period: 10s
+      retries: 3
+
+  ingest-worker:
+    build:
+      context: ..
+      dockerfile: infra/docker/Dockerfile.app
+      args:
+        APP_NAME: '@iip/ingest-worker'
+    depends_on:
+      postgres:
+        condition: service_healthy
+      redis:
+        condition: service_healthy
+    environment:
+      DATABASE_URL: postgres://${POSTGRES_USER:-postgres}:${POSTGRES_PASSWORD:-changeme}@postgres:5432/${POSTGRES_DB:-iip}?options=-c%20search_path%3Dag_catalog%2Cpublic
+      REDIS_URL: redis://redis:6379
+    healthcheck:
+      test: ["CMD-SHELL", "node -e \"console.log('alive')\" || exit 1"]
+      interval: 10s
+      timeout: 5s
+      start_period: 10s
+      retries: 3
+
+  serve-worker:
+    build:
+      context: ..
+      dockerfile: infra/docker/Dockerfile.app
+      args:
+        APP_NAME: '@iip/serve-worker'
+    depends_on:
+      postgres:
+        condition: service_healthy
+      redis:
+        condition: service_healthy
+    environment:
+      DATABASE_URL: postgres://${POSTGRES_USER:-postgres}:${POSTGRES_PASSWORD:-changeme}@postgres:5432/${POSTGRES_DB:-iip}?options=-c%20search_path%3Dag_catalog%2Cpublic
+      REDIS_URL: redis://redis:6379
+    healthcheck:
+      test: ["CMD-SHELL", "node -e \"console.log('alive')\" || exit 1"]
+      interval: 10s
+      timeout: 5s
+      start_period: 10s
+      retries: 3
+
+  audit-worker:
+    build:
+      context: ..
+      dockerfile: infra/docker/Dockerfile.app
+      args:
+        APP_NAME: '@iip/audit-worker'
+    depends_on:
+      postgres:
+        condition: service_healthy
+      redis:
+        condition: service_healthy
+    environment:
+      DATABASE_URL: postgres://${POSTGRES_USER:-postgres}:${POSTGRES_PASSWORD:-changeme}@postgres:5432/${POSTGRES_DB:-iip}?options=-c%20search_path%3Dag_catalog%2Cpublic
+      REDIS_URL: redis://redis:6379
+    healthcheck:
+      test: ["CMD-SHELL", "node -e \"console.log('alive')\" || exit 1"]
+      interval: 10s
+      timeout: 5s
+      start_period: 10s
+      retries: 3
+
+  enqueuer:
+    build:
+      context: ..
+      dockerfile: infra/docker/Dockerfile.app
+      args:
+        APP_NAME: '@iip/enqueuer'
+    depends_on:
+      postgres:
+        condition: service_healthy
+      redis:
+        condition: service_healthy
+    environment:
+      DATABASE_URL: postgres://${POSTGRES_USER:-postgres}:${POSTGRES_PASSWORD:-changeme}@postgres:5432/${POSTGRES_DB:-iip}?options=-c%20search_path%3Dag_catalog%2Cpublic
+      REDIS_URL: redis://redis:6379
+    healthcheck:
+      test: ["CMD-SHELL", "node -e \"console.log('alive')\" || exit 1"]
+      interval: 10s
+      timeout: 5s
+      start_period: 10s
+      retries: 3
+
+  web:
+    build:
+      context: ..
+      dockerfile: infra/docker/Dockerfile.app
+      args:
+        APP_NAME: '@iip/web'
+    depends_on:
+      api:
+        condition: service_healthy
+    environment:
+      NODE_ENV: production
+    healthcheck:
+      test: ["CMD-SHELL", "node -e \"console.log('alive')\" || exit 1"]
+      interval: 10s
+      timeout: 5s
+      start_period: 10s
+      retries: 3
+
+  # ─── Reverse Proxy ──────────────────────────────────────────────
+
+  caddy:
+    image: caddy:2.8-alpine
+    # Host ports are optional — set CADDY_HTTP_PORT/CADDY_HTTPS_PORT to expose
+    ports:
+      - "${CADDY_HTTP_PORT:-}:80"
+      - "${CADDY_HTTPS_PORT:-}:443"
+    volumes:
+      - ./Caddyfile:/etc/caddy/Caddyfile:ro
+      - caddydata:/data
+      - caddyconfig:/config
+    depends_on:
+      api:
+        condition: service_healthy
+      web:
+        condition: service_healthy
+
+  # ─── Observability (NFR-O-1) ────────────────────────────────────
+  # VAL-9 specifies Tempo for gate-invocation tracing — NOT Jaeger.
+
+  otel-collector:
+    image: otel/opentelemetry-collector-contrib:latest
+    command: ["--config=/etc/otelcol/config.yml"]
+    volumes:
+      - ./otel/otel-collector-config.yml:/etc/otelcol/config.yml:ro
+    depends_on:
+      - tempo
+    ports:
+      - "4317:4317"
+      - "4318:4318"
+
+  tempo:
+    image: grafana/tempo:latest
+    command: ["-config.file=/etc/tempo.yaml"]
+    volumes:
+      - ./otel/tempo.yaml:/etc/tempo.yaml:ro
+      - tempodata:/var/tempo
+    ports:
+      - "${TEMPO_HOST_PORT:-}:3200"
+      - "${TEMPO_OTLP_PORT:-}:4318"
+
+  prometheus:
+    image: prom/prometheus:latest
+    volumes:
+      - ./prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
+      - prometheusdata:/prometheus
+    ports:
+      - "9090:9090"
+
+  grafana:
+    image: grafana/grafana:latest
+    environment:
+      GF_SECURITY_ADMIN_PASSWORD: admin
+      GF_USERS_ALLOW_SIGN_UP: "false"
+    volumes:
+      - ./grafana/provisioning:/etc/grafana/provisioning:ro
+      - grafanadata:/var/lib/grafana
+    ports:
+      - "${GRAFANA_PORT:-3300}:3000"
+    depends_on:
+      - prometheus
+      - tempo
+
+# ─── Named Volumes ─────────────────────────────────────────────────
+
+volumes:
+  pgdata:
+  redisdata:
+  miniodata:
+  ollamadata:
+  caddydata:
+  caddyconfig:
+  prometheusdata:
+  grafanadata:
+  tempodata:
diff --git a/infra/docker/Dockerfile.app b/infra/docker/Dockerfile.app
new file mode 100755
index 0000000..cb79f5a
--- /dev/null
+++ b/infra/docker/Dockerfile.app
@@ -0,0 +1,55 @@
+# syntax=docker/dockerfile:1
+#
+# Shared Dockerfile for IIP app process stubs (Story 1.1 pattern).
+# Each app is a simple `console.log("alive: <name>")` stub.
+#
+# Build args:
+#   APP_NAME — the @iip/<name> workspace package to build (e.g. @iip/api)
+#
+# @rules STR-2 (6-process split)
+# @adr ADR-021
+
+FROM node:22-slim AS base
+RUN npm install -g pnpm@9.15.4
+WORKDIR /app
+
+FROM base AS deps
+COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
+COPY apps/api/package.json ./apps/api/
+COPY apps/ingest-worker/package.json ./apps/ingest-worker/
+COPY apps/serve-worker/package.json ./apps/serve-worker/
+COPY apps/audit-worker/package.json ./apps/audit-worker/
+COPY apps/enqueuer/package.json ./apps/enqueuer/
+COPY apps/web/package.json ./apps/web/
+COPY packages/contracts/package.json ./packages/contracts/
+COPY packages/config/package.json ./packages/config/
+COPY packages/db/package.json ./packages/db/
+COPY packages/render/package.json ./packages/render/
+COPY packages/rag/package.json ./packages/rag/
+COPY packages/graph/package.json ./packages/graph/
+COPY packages/citation/package.json ./packages/citation/
+COPY packages/auth/package.json ./packages/auth/
+COPY packages/editorial/package.json ./packages/editorial/
+COPY packages/eval/package.json ./packages/eval/
+COPY packages/ingest/package.json ./packages/ingest/
+COPY packages/llm/package.json ./packages/llm/
+RUN pnpm install --frozen-lockfile
+
+FROM deps AS build
+ARG APP_NAME
+COPY tsconfig.base.json tsconfig.json turbo.json ./
+COPY packages/ ./packages/
+COPY apps/ ./apps/
+RUN pnpm --filter ${APP_NAME} build
+
+FROM base AS runtime
+ARG APP_NAME
+ENV APP_NAME=${APP_NAME}
+ENV NODE_ENV=production
+COPY --from=deps /app/node_modules ./node_modules
+COPY --from=build /app/packages/ ./packages/
+COPY --from=build /app/apps/ ./apps/
+# Run the stub (proves it compiles + starts), then keep the container alive
+# so Docker Compose healthcheck can verify liveness. Real servers replace this
+# in later stories.
+CMD ["sh", "-c", "APP_DIR=$(echo $APP_NAME | cut -d/ -f2) && node apps/$APP_DIR/dist/index.js && tail -f /dev/null"]
diff --git a/infra/grafana/provisioning/dashboards/dashboard.yml b/infra/grafana/provisioning/dashboards/dashboard.yml
