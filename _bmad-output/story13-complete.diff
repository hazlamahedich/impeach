new file mode 100755
index 0000000..2842c73
--- /dev/null
+++ b/infra/Caddyfile
@@ -0,0 +1,33 @@
+# Caddyfile — IIP reverse proxy, auto-ACME TLS, rate-limit documentation
+#
+# @rules D9, SEC-9, NFR-S-3
+# @adr ADR-004
+#
+# NOTE: rate_limit is OWASP-noise mitigation only — NOT DDoS defense
+# against state-aligned actors (SEC-9, ADR-004).
+#
+# The Caddy rate_limit directive requires the caddy-ratelimit plugin
+# (github.com/mholt/caddy-ratelimit) which is NOT in the standard image.
+# NFR-S-3 rate limiting is enforced at the APPLICATION LAYER (Fastify
+# @fastify/rate-limit) per ADR-004, not just the proxy layer.
+# When a custom Caddy build is available, add:
+#   rate_limit {
+#     zone api { key {remote_host} events 100 window 1m }
+#   }
+
+{
+	admin off
+}
+
+# ── API reverse proxy ──────────────────────────────────────────────
+localhost {
+	reverse_proxy api:3001
+}
+
+# ── Web frontend reverse proxy ─────────────────────────────────────
+app.localhost {
+	reverse_proxy web:3000
+}
+
+# MinIO raw store is NOT reverse-proxied — stays private (NFR-S-5).
+# Ollama is NOT reverse-proxied — stays internal-only.
