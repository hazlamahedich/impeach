{
  "name": "@iip/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./routes/intake": {
      "types": "./src/routes/intake.ts",
      "default": "./src/routes/intake.ts"
    },
    "./routes/query": {
      "types": "./src/routes/query.ts",
      "default": "./src/routes/query.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts --passWithNoTests",
    "lint": "eslint src"
  },
  "dependencies": {
    "@iip/auth": "workspace:*",
    "@iip/config": "workspace:*",
    "@iip/contracts": "workspace:*",
    "@iip/db": "workspace:*",
    "@iip/intake": "workspace:*"
  },
  "devDependencies": {
    "fastify": "^5.9.0"
  }
}
