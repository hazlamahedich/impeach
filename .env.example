# IIP Environment Variables
#
# Copy to .env and fill in values for local development.
# NEVER commit real secrets — .env is .gitignore'd.
# Real secrets use sops+age at runtime (Story 1.11, SEC-4).

# ── PostgreSQL ─────────────────────────────────────────────────────
# Custom PG16+AGE+pgvector image (Story 1.2) — pinned to Story 1.2 digest.
IIP_PG_AGE_VECTOR_IMAGE=ghcr.io/iip/postgres-age-pgvector:pg16@sha256:9bde235139bfd00f266624e99e936c31a4abcfe7f4e287560d66ee5fb18c796e
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-local-dot-env
POSTGRES_DB=iip

# Host-side DATABASE_URL uses the mapped host port (5433 by default).
# Inside Compose containers, services override this with the `postgres` hostname.
DATABASE_URL=postgres://postgres:change-me-in-local-dot-env@localhost:5433/iip?options=-c%20search_path%3Dag_catalog%2Cpublic

# ── Redis ──────────────────────────────────────────────────────────
# Host-side URL uses the mapped host port (6380 by default).
REDIS_URL=redis://localhost:6380

# ── MinIO ──────────────────────────────────────────────────────────
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD are the current MinIO credential keys.
# (MINIO_ACCESS_KEY / MINIO_SECRET_KEY are deprecated.)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-in-local-dot-env
MINIO_ENDPOINT=http://localhost:9100
RAW_SNAPSHOTS_BUCKET=raw-snapshots

# ── Ollama ─────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# ── Grafana ────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change-me-in-local-dot-env

# ── Host port mappings ─────────────────────────────────────────────
# Defaults avoid conflicts with locally-running services.
PG_HOST_PORT=5433
REDIS_HOST_PORT=6380
MINIO_HOST_PORT=9100
MINIO_CONSOLE_PORT=9001
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443
GRAFANA_PORT=3300
