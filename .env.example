# IIP Environment Variables
#
# Copy to .env and fill in values for local development.
# NEVER commit real secrets — .env is .gitignore'd.
# Real secrets use sops+age at runtime (Story 1.11, SEC-4).

# ── PostgreSQL ─────────────────────────────────────────────────────
# Custom PG16+AGE+pgvector image (Story 1.2) — pinned to Story 1.2 digest.
IIP_PG_AGE_VECTOR_IMAGE=ghcr.io/iip/postgres-age-pgvector:pg16@sha256:9bde235139bfd00f266624e99e936c31a4abcfe7f4e287560d66ee5fb18c796e
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-local-dot-env
POSTGRES_DB=iip

# Host-side DATABASE_URL uses the mapped host port (5433 by default).
# Inside Compose containers, services override this with the `postgres` hostname.
DATABASE_URL=postgres://postgres:change-me-in-local-dot-env@localhost:5433/iip?options=-c%20search_path%3Dag_catalog%2Cpublic

# ── Redis ──────────────────────────────────────────────────────────
# Host-side URL uses the mapped host port (6380 by default).
REDIS_URL=redis://localhost:6380

# ── MinIO ──────────────────────────────────────────────────────────
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD are the current MinIO credential keys.
# (MINIO_ACCESS_KEY / MINIO_SECRET_KEY are deprecated.)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-in-local-dot-env
MINIO_ENDPOINT=http://localhost:9100
RAW_SNAPSHOTS_BUCKET=raw-snapshots

# ── Ollama ─────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# ── Grafana ────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change-me-in-local-dot-env

# ── Host port mappings ─────────────────────────────────────────────
# Defaults avoid conflicts with locally-running services.
PG_HOST_PORT=5433
REDIS_HOST_PORT=6380
MINIO_HOST_PORT=9100
MINIO_CONSOLE_PORT=9001
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443
GRAFANA_PORT=3300

# ── Rate limiting (NFR-S-3, ADR-0004) ──────────────────────────────
# Per-IP rate limiting on query endpoints (429 with Retry-After).
# Both default when absent; override to tune the throttle.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# ── API server bootstrap (TD1, Epic 3 prep) ────────────────────────
# The real API server entrypoint (apps/api/src/server.ts) reads these to boot.
PORT=3000
HOST=0.0.0.0

# Audit-worker health endpoint for the ADR-0029 §5 fail-closed circuit-breaker.
# The /query route fresh-polls this BEFORE serving any claim; unreachable → 503.
AUDIT_WORKER_HEALTH_URL=http://audit-worker:3001

# JWT issuer public keys (JSON: kid → base64 SPKI Ed25519). These SIGN JWTs;
# the API verifies them. DISTINCT from intake operator keys (which sign intake
# transitions). Generate with: openssl genpkey -algorithm Ed25519 ...
JWT_ISSUER_PUBLIC_KEYS={"issuer-1":"BASE64_SPKI_HERE"}

# System service signing key (TD5). System-emitted editorial events (audit
# circuit-breaker transitions, auth events) have no client signer, so the server
# holds a dedicated Ed25519 key. This is the sanctioned exception to the
# "server never holds private keys" rule — that rule governs OPERATOR keys.
# Private key: PKCS#8 DER, base64. Public key: SPKI DER, base64.
# Generate with: openssl genpkey -algorithm Ed25519 -out sys.key && ...
SYSTEM_SIGNING_PRIVATE_KEY=BASE64_PKCS8_HERE
SYSTEM_SIGNING_PUBLIC_KEY=BASE64_SPKI_HERE

# ── Playwright E2E ───────────────────────────────────────────────
# Base URL for the web app under test (apps/web dev server default).
PLAYWRIGHT_BASE_URL=http://localhost:3000
# Test environment selector (local | ci). CI sets retries=2, workers=1.
TEST_ENV=local

