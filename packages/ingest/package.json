{
  "name": "@iip/ingest",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./access/lawful-access-gate": {
      "types": "./src/access/lawful-access-gate.ts",
      "default": "./src/access/lawful-access-gate.ts"
    },
    "./fetch": {
      "types": "./src/fetch/index.ts",
      "default": "./src/fetch/index.ts"
    },
    "./dedupe": {
      "types": "./src/dedupe/index.ts",
      "default": "./src/dedupe/index.ts"
    },
    "./snapshot": {
      "types": "./src/snapshot/index.ts",
      "default": "./src/snapshot/index.ts"
    },
    "./provenance": {
      "types": "./src/provenance/index.ts",
      "default": "./src/provenance/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@iip/contracts": "workspace:*",
    "@iip/db": "workspace:*",
    "@iip/citation": "workspace:*",
    "minio": "8.0.3",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@iip/test-utils": "workspace:*",
    "fast-check": "^3.19.0"
  }
}
