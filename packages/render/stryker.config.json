{
  "$schema": "https://raw.githubusercontent.com/StrykerMutator/stryker/master/packages/api/schema/stryker-core.json",
  "packageManager": "pnpm",
  "reporters": ["clear-text", "progress"],
  "testRunner": "vitest",
  "coverageAnalysis": "perTest",
  "concurrency": 1,
  "thresholds": { "high": 100, "low": 100, "break": 100 },
  "mutate": [
    "packages/render/src/gate.ts",
    "packages/render/src/substring.ts"
  ],
  "ignorePatterns": [
    "**/._*",
    "**/.agent/**",
    "**/.agents/**",
    "**/.claude/**",
    "**/_bmad/**",
    "**/_bmad-output/**",
    "**/.stryker-tmp/**",
    "**/node_modules/**",
    "**/dist/**"
  ]
}
