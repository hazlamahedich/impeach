{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["@iip/eslint-plugin#build"]
    },
    "py:lint": {
      "outputs": []
    },
    "py:test": {
      "dependsOn": ["py:lint", "^build"],
      "outputs": []
    },
    "py:typecheck": {
      "dependsOn": ["py:lint"],
      "outputs": []
    }
  }
}
