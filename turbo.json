{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**"
      ]
    },
    "typecheck": {},
    "test": {
      "dependsOn": [
        "^build"
      ]
    },
    "lint": {
      "dependsOn": [
        "@iip/eslint-plugin#build"
      ]
    },
    "py:lint": {
      "outputs": []
    },
    "py:test": {
      "dependsOn": [
        "py:lint",
        "^build"
      ],
      "outputs": []
    },
    "py:typecheck": {
      "dependsOn": [
        "py:lint"
      ],
      "outputs": []
    },
    "eval:smoke": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "eval:full": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [],
      "cache": false
    }
  }
}
