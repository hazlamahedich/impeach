# Secrets Template — DO NOT COMMIT WITH REAL VALUES
#
# Copy this file to secrets/dev.sops.yaml, fill in real values, then encrypt:
#   sops --encrypt --in-place secrets/dev.sops.yaml
#
# The encrypted file is safe to commit. This plaintext template is NOT.
# Refs: D7, NFR-S-4, SEC-4, ADR-019

database:
  # Postgres DSN for the custom PG16+AGE+pgvector image
  # Use the same image digest pinned in infra/docker-compose.yml
  DATABASE_URL: "postgres://postgres:CHANGE_ME@localhost:5433/iip?options=-c%20search_path%3Dag_catalog%2Cpublic"

redis:
  # BullMQ-compatible Redis (redis:7-alpine only — no Dragonfly/KeyDB)
  REDIS_URL: "redis://localhost:6380"

minio:
  MINIO_ROOT_USER: "CHANGE_ME"
  MINIO_ROOT_PASSWORD: "CHANGE_ME"
  MINIO_ENDPOINT: "http://localhost:9000"

ollama:
  OLLAMA_HOST: "http://localhost:11434"

jwt:
  # Story 2.2 will replace this with per-issued JWT kid rotation
  JWT_SECRET: "CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"
  JWT_ISSUER: "iip"
  # TD1 (Epic 3 prep) — JWT issuer public keys (JSON: kid → base64 SPKI Ed25519).
  # These SIGN JWTs; the API verifies them. Distinct from intake operator keys.
  # Generate a keypair: openssl genpkey -algorithm Ed25519 -out issuer.key
  #                       openssl pkey -in issuer.key -pubout -outform DER | base64
  JWT_ISSUER_PUBLIC_KEYS: '{"issuer-1":"CHANGE_ME_BASE64_SPKI"}'

api:
  # TD1 (Epic 3 prep) — API server bootstrap env vars.
  PORT: "3000"
  HOST: "0.0.0.0"
  # Audit-worker health endpoint for the ADR-0029 §5 fail-closed circuit-breaker.
  AUDIT_WORKER_HEALTH_URL: "http://audit-worker:3001"

system_signing:
  # TD5 (Epic 3 prep) — System service signing key for editorial-log events.
  # System-emitted events (audit circuit-breaker, auth events) have no client
  # signer, so the server holds a dedicated Ed25519 key. This is the sanctioned
  # exception to "server never holds private keys" (that rule governs operator keys).
  # Generate: openssl genpkey -algorithm Ed25519 -out sys.key
  #   Private (PKCS#8 DER, base64): openssl pkey -in sys.key -outform DER | base64
  #   Public  (SPKI DER, base64):   openssl pkey -in sys.key -pubout -outform DER | base64
  SYSTEM_SIGNING_PRIVATE_KEY: "CHANGE_ME_BASE64_PKCS8"
  SYSTEM_SIGNING_PUBLIC_KEY: "CHANGE_ME_BASE64_SPKI"

grafana:
  GRAFANA_ADMIN_PASSWORD: "CHANGE_ME"

# CI runner only (SEC-4, ADR-019):
# The age private key NEVER enters the repo. It lives at
# ~/.config/sops/age/keys.txt on the deploy runner only.
# CI runners receive decrypted values via OIDC ephemeral tokens.
