{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "packages/*/src/**/*.ts",
    "apps/*/src/**/*.ts",
    "tests/**/*.ts",
    "*.config.ts",
    "vitest.workspace.ts",
    "eslint.config.js"
  ],
  "exclude": [
    "tests/lint-fixtures/**"
  ]
}
